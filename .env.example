TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ALLOWED_USER_ID=123456789
## Optional private chat IDs to pin the bot to specific approved private chats.
## If unset, the allowed user may use the bot in their private chat with the bot.
# TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
## Optional smaller model that sees each task first and escalates harder ones to OLLAMA_MODEL.
# OLLAMA_FAST_MODEL=qwen2.5:1.5b
## Optional vision-capable model for OCR and element finding. Defaults to OLLAMA_MODEL.
# OLLAMA_VISION_MODEL=gemma4:latest
AGENT_MAX_ITERATIONS=4
DATABASE_PATH=gravity-claw.db
WORKSPACE_ROOT=.
## Optional extra trusted roots for file tools and shell cwd. Separate multiple paths with ; or new lines.
# TOOL_ALLOWED_ROOTS=C:\Users\User\Desktop;C:\Users\User\Documents
## If Windows redirects Downloads or Documents to another drive, add that redirected path too.
# TOOL_ALLOWED_ROOTS=C:\Users\User;D:\DL
LOG_LEVEL=info
# TZ=America/Vancouver
